<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>AI-Based Tumor Detection Simulation System</display-name>

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Login Servlet                                         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.tumor.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Signup Servlet                                        -->
    <!-- ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.tumor.servlet.SignupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Patient Servlet                                       -->
    <!-- ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>PatientServlet</servlet-name>
        <servlet-class>com.tumor.servlet.PatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientServlet</servlet-name>
        <url-pattern>/patients</url-pattern>
    </servlet-mapping>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Image Upload Servlet                                  -->
    <!-- ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>ImageUploadServlet</servlet-name>
        <servlet-class>com.tumor.servlet.ImageUploadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ImageUploadServlet</servlet-name>
        <url-pattern>/upload</url-pattern>
    </servlet-mapping>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Prediction Servlet                                    -->
    <!-- ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>PredictionServlet</servlet-name>
        <servlet-class>com.tumor.servlet.PredictionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PredictionServlet</servlet-name>
        <url-pattern>/predict</url-pattern>
    </servlet-mapping>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Access Log Servlet                                    -->
    <!-- ══════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>AccessLogServlet</servlet-name>
        <servlet-class>com.tumor.servlet.AccessLogServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AccessLogServlet</servlet-name>
        <url-pattern>/logs</url-pattern>
    </servlet-mapping>

    <!-- Session Timeout (30 minutes) -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
